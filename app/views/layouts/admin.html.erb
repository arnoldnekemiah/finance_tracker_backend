<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? yield(:title) : "Finance Tracker Admin" %></title>
  
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Chart.js for analytics -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <!-- Font Awesome for icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  
  <style>
    body {
      background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
    }
    .sidebar-active {
      background: linear-gradient(45deg, #FFD700, #FFA500);
      color: #000;
      font-weight: 600;
    }
    .sidebar-item:hover {
      background: linear-gradient(45deg, #FFD700, #FFA500);
      color: #000;
      transform: translateX(4px);
      transition: all 0.3s ease;
    }
    .sidebar {
      background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
      border-right: 1px solid #dee2e6;
    }
    .table-row:hover {
      background-color: #fffbf0;
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(255, 215, 0, 0.1);
    }
    .admin-card {
      transition: all 0.3s ease;
      border: 1px solid rgba(255, 215, 0, 0.1);
    }
    .admin-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(255, 215, 0, 0.15);
      border-color: rgba(255, 215, 0, 0.3);
    }
    .gold-accent {
      background: linear-gradient(45deg, #FFD700, #FFA500);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .gold-bg {
      background: linear-gradient(45deg, #FFD700, #FFA500);
    }
    .gold-border {
      border-color: #FFD700;
    }
  </style>
</head>
<body class="bg-gray-50">
  <div class="flex h-screen">
    <!-- Sidebar -->
    <div class="sidebar text-gray-800 w-64 flex-shrink-0">
      <div class="p-4 border-b border-gray-300">
        <h1 class="text-xl font-bold gold-accent">
          <i class="fas fa-crown mr-2"></i>
          Finance Admin
        </h1>
      </div>
      
      <nav class="mt-4">
        <%= link_to admin_dashboard_path, class: "flex items-center px-4 py-3 sidebar-item #{'sidebar-active' if current_page?(admin_dashboard_path)}" do %>
          <i class="fas fa-tachometer-alt mr-3"></i>
          Dashboard
        <% end %>
        
        <%= link_to admin_users_path, class: "flex items-center px-4 py-3 sidebar-item #{'sidebar-active' if current_page?(admin_users_path)}" do %>
          <i class="fas fa-users mr-3"></i>
          Users
        <% end %>
        
        <%= link_to admin_analytics_path, class: "flex items-center px-4 py-3 sidebar-item #{'sidebar-active' if controller_name == 'analytics'}" do %>
          <i class="fas fa-chart-bar mr-3"></i>
          Analytics
        <% end %>
        
        <%= link_to admin_reports_path, class: "flex items-center px-4 py-3 sidebar-item #{'sidebar-active' if controller_name == 'reports'}" do %>
          <i class="fas fa-file-alt mr-3"></i>
          Reports
        <% end %>
        
        <div class="border-t border-gray-300 mt-4 pt-4">
          <%= link_to admin_settings_path, class: "flex items-center px-4 py-3 sidebar-item" do %>
            <i class="fas fa-cog mr-3"></i>
            Settings
          <% end %>
          
          <%= link_to admin_logout_path, method: :delete, class: "flex items-center px-4 py-3 sidebar-item text-red-600 hover:text-red-700" do %>
            <i class="fas fa-sign-out-alt mr-3"></i>
            Logout
          <% end %>
        </div>
      </nav>
    </div>
    
    <!-- Main Content -->
    <div class="flex-1 flex flex-col overflow-hidden">
      <!-- Top Bar -->
      <header class="bg-white shadow-sm border-b border-gray-200 px-6 py-4">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="text-2xl font-semibold text-gray-800">
              <%= content_for?(:page_title) ? yield(:page_title) : "Dashboard" %>
            </h2>
            <p class="text-gray-600 text-sm">
              <%= content_for?(:page_description) ? yield(:page_description) : "Welcome to the admin panel" %>
            </p>
          </div>
          
          <div class="flex items-center space-x-4">
            <div class="text-sm text-gray-600">
              <i class="fas fa-user-circle mr-1"></i>
              <%= current_user&.full_name || "Admin User" %>
            </div>
            
            <div class="text-sm text-gray-500">
              <%= Time.current.strftime("%B %d, %Y") %>
            </div>
          </div>
        </div>
      </header>
      
      <!-- Page Content -->
      <main class="flex-1 overflow-y-auto p-6">
        <% if notice %>
          <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4" role="alert">
            <i class="fas fa-check-circle mr-2"></i>
            <%= notice %>
          </div>
        <% end %>
        
        <% if alert %>
          <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4" role="alert">
            <i class="fas fa-exclamation-triangle mr-2"></i>
            <%= alert %>
          </div>
        <% end %>
        
        <%= yield %>
      </main>
    </div>
  </div>
  
  <!-- JavaScript -->
  <script>
    // Auto-hide alerts after 5 seconds
    setTimeout(() => {
      const alerts = document.querySelectorAll('[role="alert"]');
      alerts.forEach(alert => {
        alert.style.transition = 'opacity 0.5s';
        alert.style.opacity = '0';
        setTimeout(() => alert.remove(), 500);
      });
    }, 5000);
    
    // Add loading states to buttons
    document.addEventListener('DOMContentLoaded', function() {
      const buttons = document.querySelectorAll('button[type="submit"], .btn-primary');
      buttons.forEach(button => {
        button.addEventListener('click', function() {
          this.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Loading...';
          this.disabled = true;
        });
      });
    });
  </script>
</body>
</html>
