<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? yield(:title) : "Accountanta Admin" %></title>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'sans-serif'] },
          colors: {
            brand: { 50: '#fffbeb', 100: '#fef3c7', 200: '#fde68a', 300: '#fcd34d', 400: '#fbbf24', 500: '#f59e0b', 600: '#d97706', 700: '#b45309' },
            dark: { 800: '#1e1e2e', 900: '#11111b', 950: '#0a0a14' }
          }
        }
      }
    }
  </script>

  <style>
    body { font-family: 'Inter', sans-serif; }
    .sidebar { background: linear-gradient(180deg, #11111b 0%, #1e1e2e 100%); }
    .sidebar-item { transition: all 0.2s ease; border-radius: 8px; margin: 2px 8px; }
    .sidebar-item:hover { background: rgba(251, 191, 36, 0.1); color: #fbbf24; }
    .sidebar-active { background: rgba(251, 191, 36, 0.15) !important; color: #fbbf24 !important; font-weight: 600; border-left: 3px solid #fbbf24; }
    .stat-card { transition: all 0.3s ease; }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(0,0,0,0.08); }
    .glass { background: rgba(255,255,255,0.8); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.3); }
  </style>
</head>
<body class="bg-gray-50 text-gray-900">
  <div class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="sidebar w-64 flex-shrink-0 flex flex-col text-gray-300">
      <div class="px-5 py-6 border-b border-white/10">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-brand-400 to-brand-600 flex items-center justify-center">
            <i data-lucide="bar-chart-3" class="w-5 h-5 text-white"></i>
          </div>
          <div>
            <h1 class="text-lg font-bold text-white tracking-tight">Accountanta</h1>
            <p class="text-[11px] text-gray-500 -mt-0.5">Admin Panel</p>
          </div>
        </div>
      </div>

      <nav class="flex-1 py-4 space-y-1 overflow-y-auto">
        <p class="px-5 text-[10px] font-semibold uppercase tracking-widest text-gray-600 mb-2">Main</p>

        <%= link_to admin_dashboard_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm sidebar-item #{'sidebar-active' if current_page?(admin_dashboard_path)}" do %>
          <i data-lucide="layout-dashboard" class="w-4 h-4"></i> Dashboard
        <% end %>

        <%= link_to admin_users_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm sidebar-item #{'sidebar-active' if current_page?(admin_users_path)}" do %>
          <i data-lucide="users" class="w-4 h-4"></i> Users
        <% end %>

        <%= link_to admin_analytics_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm sidebar-item #{'sidebar-active' if controller_name == 'analytics'}" do %>
          <i data-lucide="trending-up" class="w-4 h-4"></i> Analytics
        <% end %>

        <%= link_to admin_reports_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm sidebar-item #{'sidebar-active' if controller_name == 'reports'}" do %>
          <i data-lucide="file-text" class="w-4 h-4"></i> Reports
        <% end %>

        <div class="border-t border-white/5 mt-4 pt-4">
          <p class="px-5 text-[10px] font-semibold uppercase tracking-widest text-gray-600 mb-2">System</p>

          <%= link_to admin_settings_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm sidebar-item" do %>
            <i data-lucide="settings" class="w-4 h-4"></i> Settings
          <% end %>

          <%= link_to admin_logout_path, method: :delete, class: "flex items-center gap-3 px-4 py-2.5 text-sm sidebar-item text-red-400 hover:text-red-300" do %>
            <i data-lucide="log-out" class="w-4 h-4"></i> Logout
          <% end %>
        </div>
      </nav>

      <div class="px-4 py-4 border-t border-white/5">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-brand-500/20 flex items-center justify-center">
            <i data-lucide="user" class="w-4 h-4 text-brand-400"></i>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-white truncate"><%= current_user&.full_name || "Admin" %></p>
            <p class="text-[11px] text-gray-500 truncate"><%= current_user&.email %></p>
          </div>
        </div>
      </div>
    </aside>

    <!-- Main -->
    <div class="flex-1 flex flex-col overflow-hidden">
      <header class="glass border-b border-gray-200/60 px-8 py-4">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="text-xl font-semibold text-gray-900"><%= content_for?(:page_title) ? yield(:page_title) : "Dashboard" %></h2>
            <p class="text-sm text-gray-500 mt-0.5"><%= content_for?(:page_description) ? yield(:page_description) : "Overview" %></p>
          </div>
          <div class="flex items-center gap-4">
            <span class="text-sm text-gray-500"><%= Time.current.strftime("%b %d, %Y") %></span>
          </div>
        </div>
      </header>

      <main class="flex-1 overflow-y-auto p-8">
        <% if notice %>
          <div class="mb-6 p-4 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm flex items-center gap-2" role="alert">
            <i data-lucide="check-circle-2" class="w-4 h-4"></i> <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div class="mb-6 p-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm flex items-center gap-2" role="alert">
            <i data-lucide="alert-triangle" class="w-4 h-4"></i> <%= alert %>
          </div>
        <% end %>
        <%= yield %>
      </main>
    </div>
  </div>

  <script>lucide.createIcons();</script>
  <script>
    setTimeout(() => {
      document.querySelectorAll('[role="alert"]').forEach(el => {
        el.style.transition = 'opacity 0.4s';
        el.style.opacity = '0';
        setTimeout(() => el.remove(), 400);
      });
    }, 5000);
  </script>
</body>
</html>
