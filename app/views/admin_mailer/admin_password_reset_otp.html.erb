<div style="max-width: 600px; margin: 0 auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0D1117; color: #c9d1d9; padding: 40px 30px; border-radius: 12px;">
  <div style="text-align: center; margin-bottom: 32px;">
    <div style="display: inline-block; width: 48px; height: 48px; background: linear-gradient(135deg, #00D4AA, #00B894); border-radius: 12px; line-height: 48px; font-size: 24px; font-weight: bold; color: #0D1117;">A</div>
    <h1 style="margin: 12px 0 4px; font-size: 24px; color: #ffffff;">Accountanta</h1>
    <p style="margin: 0; color: #8b949e; font-size: 14px;">Admin Password Reset</p>
  </div>

  <div style="background: #161B22; border: 1px solid #30363d; border-radius: 8px; padding: 24px; margin-bottom: 24px;">
    <p style="margin: 0 0 16px; font-size: 16px; color: #e6edf3;">Hello <%= @user.first_name %>,</p>
    <p style="margin: 0 0 24px; color: #c9d1d9;">
      Use the following code to reset your admin password. This code expires in <strong style="color: #00D4AA;">10 minutes</strong>.
    </p>

    <div style="text-align: center; margin: 24px 0;">
      <div style="display: inline-block; background: #0D1117; border: 2px solid #00D4AA; border-radius: 8px; padding: 16px 40px; letter-spacing: 8px; font-size: 32px; font-weight: 700; color: #00D4AA; font-family: 'JetBrains Mono', monospace;">
        <%= @otp %>
      </div>
    </div>

    <p style="margin: 0; color: #8b949e; font-size: 13px; text-align: center;">
      Do not share this code with anyone. If you didn't request this, please secure your account immediately.
    </p>
  </div>

  <p style="color: #8b949e; font-size: 12px; text-align: center; margin: 0;">
    &copy; <%= Date.current.year %> Accountanta
  </p>
</div>
