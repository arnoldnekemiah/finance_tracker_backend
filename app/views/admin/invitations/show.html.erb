<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Accept Invitation — Accountanta</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <style>
    body { font-family: 'DM Sans', sans-serif; background: #0D1117; color: #E6EDF3; }
    .font-mono { font-family: 'IBM Plex Mono', monospace; }
    .input-field {
      background: rgba(13,17,23,0.8); border: 1px solid #30363D; color: #E6EDF3; transition: all 0.2s;
    }
    .input-field:focus { border-color: #00D4AA; box-shadow: 0 0 0 3px rgba(0,212,170,0.15); }
    .input-field::placeholder { color: #484F58; }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <div class="bg-[#161B22] border border-[#21262D] rounded-2xl p-8">
      <div class="text-center mb-8">
        <div class="mx-auto w-14 h-14 rounded-xl bg-gradient-to-br from-[#00D4AA] to-[#00B894] flex items-center justify-center mb-4" style="box-shadow: 0 4px 20px rgba(0,212,170,0.3);">
          <i data-lucide="shield-check" class="w-7 h-7 text-[#0D1117]"></i>
        </div>
        <h1 class="text-2xl font-bold text-white">Welcome to Accountanta</h1>
        <p class="text-[#8B949E] text-sm mt-2">
          <strong class="text-[#00D4AA]"><%= @invitation.inviter&.full_name %></strong> invited you to join as an administrator.
        </p>
      </div>

      <% if flash[:alert] %>
        <div class="p-3 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 text-sm mb-4">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <% existing_user = User.find_by(email: @invitation.email) %>
      <% if existing_user %>
        <p class="text-sm text-[#8B949E] mb-4">An account with <strong class="text-white"><%= @invitation.email %></strong> already exists. Click below to accept admin access.</p>
        <%= form_with url: admin_process_invitation_path(token: @invitation.token), method: :post, local: true do |f| %>
          <%= f.submit "Accept Admin Access", class: "w-full py-3 rounded-lg bg-gradient-to-r from-[#00D4AA] to-[#00B894] text-[#0D1117] font-semibold text-sm cursor-pointer hover:shadow-lg transition-all" %>
        <% end %>
      <% else %>
        <p class="text-sm text-[#8B949E] mb-4">Set up your admin account for <strong class="text-white font-mono"><%= @invitation.email %></strong></p>
        <%= form_with url: admin_process_invitation_path(token: @invitation.token), method: :post, local: true, class: "space-y-4" do |f| %>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-mono uppercase tracking-wider text-[#8B949E] mb-1">First Name</label>
              <%= f.text_field :first_name, required: true, class: "input-field w-full px-4 py-2.5 rounded-lg text-sm outline-none", placeholder: "John" %>
            </div>
            <div>
              <label class="block text-xs font-mono uppercase tracking-wider text-[#8B949E] mb-1">Last Name</label>
              <%= f.text_field :last_name, required: true, class: "input-field w-full px-4 py-2.5 rounded-lg text-sm outline-none", placeholder: "Doe" %>
            </div>
          </div>
          <div>
            <label class="block text-xs font-mono uppercase tracking-wider text-[#8B949E] mb-1">Password</label>
            <%= f.password_field :password, required: true, class: "input-field w-full px-4 py-2.5 rounded-lg text-sm outline-none", placeholder: "Min 6 characters" %>
          </div>
          <div>
            <label class="block text-xs font-mono uppercase tracking-wider text-[#8B949E] mb-1">Confirm Password</label>
            <%= f.password_field :password_confirmation, required: true, class: "input-field w-full px-4 py-2.5 rounded-lg text-sm outline-none", placeholder: "Confirm password" %>
          </div>
          <%= f.submit "Create Account & Accept", class: "w-full py-3 rounded-lg bg-gradient-to-r from-[#00D4AA] to-[#00B894] text-[#0D1117] font-semibold text-sm cursor-pointer hover:shadow-lg transition-all" %>
        <% end %>
      <% end %>
    </div>
    <p class="text-center text-[#484F58] text-xs mt-6 font-mono">&copy; <%= Date.current.year %> Accountanta</p>
  </div>
  <script>lucide.createIcons();</script>
</body>
</html>
