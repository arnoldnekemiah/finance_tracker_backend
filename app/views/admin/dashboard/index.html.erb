<% content_for :page_title, "Dashboard" %>
<% content_for :page_description, "Platform overview — real-time metrics" %>

<div class="space-y-6">
  <!-- KPI Strip -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="card stat-glow p-5 animate-card">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-mono uppercase tracking-wider text-fg-muted">Total Users</span>
        <div class="w-8 h-8 rounded-lg bg-accent/10 flex items-center justify-center">
          <i data-lucide="users" class="w-4 h-4 text-accent"></i>
        </div>
      </div>
      <p class="text-2xl font-bold text-fg-primary font-mono"><%= number_with_delimiter(@stats[:total_users]) %></p>
      <p class="text-xs text-fg-muted mt-1"><span class="text-accent">+<%= @stats[:new_registrations_month] %></span> this month</p>
    </div>

    <div class="card stat-glow p-5 animate-card">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-mono uppercase tracking-wider text-fg-muted">Active Users (30d)</span>
        <div class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center">
          <i data-lucide="activity" class="w-4 h-4 text-blue-400"></i>
        </div>
      </div>
      <p class="text-2xl font-bold text-fg-primary font-mono"><%= number_with_delimiter(@stats[:active_users]) %></p>
      <p class="text-xs text-fg-muted mt-1"><%= @stats[:active_users_today] %> active today</p>
    </div>

    <div class="card stat-glow p-5 animate-card">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-mono uppercase tracking-wider text-fg-muted">Transactions</span>
        <div class="w-8 h-8 rounded-lg bg-purple-500/10 flex items-center justify-center">
          <i data-lucide="arrow-left-right" class="w-4 h-4 text-purple-400"></i>
        </div>
      </div>
      <p class="text-2xl font-bold text-fg-primary font-mono"><%= number_with_delimiter(@stats[:total_transactions]) %></p>
      <p class="text-xs text-fg-muted mt-1"><span class="text-purple-400">+<%= @stats[:transactions_this_month] %></span> this month</p>
    </div>

    <div class="card stat-glow p-5 animate-card">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-mono uppercase tracking-wider text-fg-muted">Net Platform Value</span>
        <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center">
          <i data-lucide="wallet" class="w-4 h-4 text-emerald-400"></i>
        </div>
      </div>
      <p class="text-2xl font-bold text-fg-primary font-mono">$<%= number_with_delimiter(@financial_metrics[:total_account_balance]) %></p>
      <p class="text-xs text-fg-muted mt-1">Across all accounts</p>
    </div>
  </div>

  <!-- Charts Row -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <!-- Transaction Volume Chart (2 cols) -->
    <div class="card p-5 lg:col-span-2 animate-card">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h3 class="text-sm font-semibold text-fg-primary">Transaction Volume</h3>
          <p class="text-xs text-fg-muted font-mono">Income vs Expenses — Last 30 days</p>
        </div>
        <div class="flex gap-3 text-xs font-mono">
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-accent"></span> Income</span>
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-red-400"></span> Expenses</span>
        </div>
      </div>
      <canvas id="transactionVolumeChart" height="200"></canvas>
    </div>

    <!-- Category Breakdown (1 col) -->
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-1">Category Breakdown</h3>
      <p class="text-xs text-fg-muted font-mono mb-4">Top spending categories</p>
      <canvas id="categoryChart" height="200"></canvas>
      <div class="mt-4 space-y-2">
        <% @financial_metrics[:top_expense_categories].first(5).each do |cat| %>
          <div class="flex items-center justify-between">
            <span class="text-xs text-fg-secondary"><%= cat[:category] %></span>
            <span class="text-xs font-mono text-fg-primary">$<%= number_with_delimiter(cat[:amount]) %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Middle Row: User Growth + Financial Summary -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <!-- User Growth -->
    <div class="card p-5 animate-card">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h3 class="text-sm font-semibold text-fg-primary">User Growth</h3>
          <p class="text-xs text-fg-muted font-mono">Registrations — Last 30 days</p>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-xs font-mono text-accent"><%= @user_metrics[:google_users] %> Google</span>
          <span class="text-xs text-fg-muted">|</span>
          <span class="text-xs font-mono text-fg-secondary"><%= @user_metrics[:email_users] %> Email</span>
        </div>
      </div>
      <canvas id="userGrowthChart" height="180"></canvas>
    </div>

    <!-- Financial Summary Cards -->
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-4">Financial Overview</h3>
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-surface-50 rounded-lg p-3 border border-surface-300">
          <p class="text-xs text-fg-muted font-mono">Income (MTD)</p>
          <p class="text-lg font-bold text-accent font-mono">$<%= number_with_delimiter(@financial_metrics[:income_this_month]) %></p>
        </div>
        <div class="bg-surface-50 rounded-lg p-3 border border-surface-300">
          <p class="text-xs text-fg-muted font-mono">Expenses (MTD)</p>
          <p class="text-lg font-bold text-red-400 font-mono">$<%= number_with_delimiter(@financial_metrics[:expenses_this_month]) %></p>
        </div>
        <div class="bg-surface-50 rounded-lg p-3 border border-surface-300">
          <p class="text-xs text-fg-muted font-mono">Debt Outstanding</p>
          <p class="text-lg font-bold text-amber-400 font-mono">$<%= number_with_delimiter(@financial_metrics[:total_debt_outstanding]) %></p>
        </div>
        <div class="bg-surface-50 rounded-lg p-3 border border-surface-300">
          <p class="text-xs text-fg-muted font-mono">Savings Progress</p>
          <% savings_pct = @financial_metrics[:total_saving_goals_target].to_f > 0 ? ((@financial_metrics[:total_saving_goals_saved].to_f / @financial_metrics[:total_saving_goals_target].to_f) * 100).round(1) : 0 %>
          <p class="text-lg font-bold text-blue-400 font-mono"><%= savings_pct %>%</p>
          <div class="mt-1 h-1.5 bg-surface-300 rounded-full overflow-hidden">
            <div class="h-full bg-blue-400 rounded-full" style="width: <%= [savings_pct, 100].min %>%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Users Table + Debt Overview -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <!-- Recent Signups -->
    <div class="card p-5 lg:col-span-2 animate-card">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h3 class="text-sm font-semibold text-fg-primary">Recent Signups</h3>
          <p class="text-xs text-fg-muted font-mono">Latest platform registrations</p>
        </div>
        <%= link_to admin_users_path, class: "text-xs text-accent hover:text-accent-light font-mono" do %>
          View All →
        <% end %>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="text-left text-[11px] font-mono uppercase tracking-wider text-fg-muted border-b border-surface-300">
              <th class="pb-2 pr-4">#</th>
              <th class="pb-2 pr-4">User</th>
              <th class="pb-2 pr-4">Email</th>
              <th class="pb-2 pr-4">Auth</th>
              <th class="pb-2 pr-4">Joined</th>
              <th class="pb-2">Status</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_activity.each_with_index do |activity, idx| %>
              <tr class="table-row border-b border-surface-300/50">
                <td class="py-2.5 pr-4 text-xs text-fg-muted font-mono"><%= idx + 1 %></td>
                <td class="py-2.5 pr-4">
                  <div class="flex items-center gap-2">
                    <div class="w-7 h-7 rounded-full bg-accent/10 flex items-center justify-center">
                      <span class="text-[10px] font-bold text-accent"><%= activity[:user][:name]&.first %></span>
                    </div>
                    <span class="text-sm text-fg-primary"><%= activity[:user][:name] %></span>
                  </div>
                </td>
                <td class="py-2.5 pr-4 text-xs text-fg-secondary font-mono"><%= activity[:user][:email] %></td>
                <td class="py-2.5 pr-4">
                  <span class="text-[10px] font-mono px-2 py-0.5 rounded-full bg-surface-300 text-fg-secondary"><%= activity[:event_type] %></span>
                </td>
                <td class="py-2.5 pr-4 text-xs text-fg-muted font-mono"><%= time_ago_in_words(activity[:created_at]) %></td>
                <td class="py-2.5">
                  <span class="badge-active text-[10px] font-mono px-2 py-0.5 rounded-full">Active</span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Debt Overview + System Health -->
    <div class="space-y-4">
      <div class="card p-5 animate-card">
        <h3 class="text-sm font-semibold text-fg-primary mb-3">Debt Overview</h3>
        <% if @platform_metrics.present? && @platform_metrics[:debt_status_breakdown].present? %>
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-xs text-fg-secondary">Pending</span>
              <span class="text-xs font-mono text-amber-400"><%= @platform_metrics[:debt_status_breakdown][:pending] %> ($<%= number_with_delimiter(@platform_metrics[:debt_status_breakdown][:pending_amount]) %>)</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-fg-secondary">Overdue</span>
              <span class="text-xs font-mono text-red-400"><%= @platform_metrics[:debt_status_breakdown][:overdue] %> ($<%= number_with_delimiter(@platform_metrics[:debt_status_breakdown][:overdue_amount]) %>)</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-fg-secondary">Paid</span>
              <span class="text-xs font-mono text-accent"><%= @platform_metrics[:debt_status_breakdown][:paid] %></span>
            </div>
          </div>
        <% else %>
          <p class="text-xs text-fg-muted">No debt data available</p>
        <% end %>
      </div>

      <div class="card p-5 animate-card">
        <h3 class="text-sm font-semibold text-fg-primary mb-3">System Health</h3>
        <div class="space-y-2.5">
          <div class="flex items-center justify-between">
            <span class="text-xs text-fg-secondary">Database</span>
            <span class="badge-active text-[10px] font-mono px-2 py-0.5 rounded-full">Healthy</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-fg-secondary">Memory</span>
            <span class="text-xs font-mono text-fg-primary"><%= number_to_human_size(@health[:memory_usage].to_i * 1024) %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-fg-secondary">Rails</span>
            <span class="text-xs font-mono text-fg-primary"><%= @health[:rails_version] %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-fg-secondary">Environment</span>
            <span class="text-[10px] font-mono px-2 py-0.5 rounded-full bg-blue-500/10 text-blue-400"><%= @health[:rails_env] %></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="card p-5 animate-card">
    <h3 class="text-sm font-semibold text-fg-primary mb-4">Quick Actions</h3>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
      <%= link_to admin_analytics_export_data_path(format: 'csv'), class: "flex items-center gap-3 p-3 rounded-lg bg-surface-50 border border-surface-300 hover:border-accent/30 hover:bg-accent/5 transition-all" do %>
        <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center">
          <i data-lucide="download" class="w-4 h-4 text-accent"></i>
        </div>
        <div>
          <p class="text-sm font-medium text-fg-primary">Export CSV</p>
          <p class="text-[11px] text-fg-muted">Download reports</p>
        </div>
      <% end %>

      <%= link_to admin_invitations_path, class: "flex items-center gap-3 p-3 rounded-lg bg-surface-50 border border-surface-300 hover:border-accent/30 hover:bg-accent/5 transition-all" do %>
        <div class="w-9 h-9 rounded-lg bg-purple-500/10 flex items-center justify-center">
          <i data-lucide="mail-plus" class="w-4 h-4 text-purple-400"></i>
        </div>
        <div>
          <p class="text-sm font-medium text-fg-primary">Invite Admin</p>
          <p class="text-[11px] text-fg-muted">Send invitation</p>
        </div>
      <% end %>

      <%= link_to admin_users_path, class: "flex items-center gap-3 p-3 rounded-lg bg-surface-50 border border-surface-300 hover:border-accent/30 hover:bg-accent/5 transition-all" do %>
        <div class="w-9 h-9 rounded-lg bg-blue-500/10 flex items-center justify-center">
          <i data-lucide="users" class="w-4 h-4 text-blue-400"></i>
        </div>
        <div>
          <p class="text-sm font-medium text-fg-primary">Manage Users</p>
          <p class="text-[11px] text-fg-muted">View all users</p>
        </div>
      <% end %>

      <%= link_to admin_audit_logs_path, class: "flex items-center gap-3 p-3 rounded-lg bg-surface-50 border border-surface-300 hover:border-accent/30 hover:bg-accent/5 transition-all" do %>
        <div class="w-9 h-9 rounded-lg bg-amber-500/10 flex items-center justify-center">
          <i data-lucide="shield-check" class="w-4 h-4 text-amber-400"></i>
        </div>
        <div>
          <p class="text-sm font-medium text-fg-primary">Audit Logs</p>
          <p class="text-[11px] text-fg-muted">Review activity</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const chartDefaults = {
    responsive: true,
    plugins: { legend: { display: false } },
    scales: {
      x: { grid: { color: '#21262D', drawBorder: false }, ticks: { color: '#484F58', font: { family: 'IBM Plex Mono', size: 10 } } },
      y: { grid: { color: '#21262D', drawBorder: false }, ticks: { color: '#484F58', font: { family: 'IBM Plex Mono', size: 10 } }, beginAtZero: true }
    }
  };

  // Transaction Volume Chart (Income vs Expenses)
  const tvCtx = document.getElementById('transactionVolumeChart')?.getContext('2d');
  if (tvCtx) {
    const incomeData = <%= raw(@financial_metrics[:income_by_day].to_json) %>;
    const expenseData = <%= raw(@financial_metrics[:expenses_by_day].to_json) %>;
    const allDates = [...new Set([...Object.keys(incomeData), ...Object.keys(expenseData)])].sort();

    new Chart(tvCtx, {
      type: 'line',
      data: {
        labels: allDates.map(d => d.slice(5)),
        datasets: [
          {
            label: 'Income',
            data: allDates.map(d => incomeData[d] || 0),
            borderColor: '#00D4AA',
            backgroundColor: 'rgba(0,212,170,0.08)',
            tension: 0.4, fill: true, borderWidth: 2, pointRadius: 0, pointHoverRadius: 5
          },
          {
            label: 'Expenses',
            data: allDates.map(d => expenseData[d] || 0),
            borderColor: '#F85149',
            backgroundColor: 'rgba(248,81,73,0.05)',
            tension: 0.4, fill: true, borderWidth: 2, pointRadius: 0, pointHoverRadius: 5
          }
        ]
      },
      options: chartDefaults
    });
  }

  // Category Donut
  const catCtx = document.getElementById('categoryChart')?.getContext('2d');
  if (catCtx) {
    const categories = <%= raw(@financial_metrics[:top_expense_categories].to_json) %>;
    new Chart(catCtx, {
      type: 'doughnut',
      data: {
        labels: categories.map(c => c.category),
        datasets: [{
          data: categories.map(c => c.amount),
          backgroundColor: ['#00D4AA', '#00B4D8', '#7C3AED', '#F59E0B', '#F85149', '#8B949E'],
          borderWidth: 0, hoverOffset: 6
        }]
      },
      options: {
        responsive: true,
        cutout: '65%',
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#161B22', borderColor: '#30363D', borderWidth: 1,
            titleFont: { family: 'IBM Plex Mono' }, bodyFont: { family: 'IBM Plex Mono' }
          }
        }
      }
    });
  }

  // User Growth Chart
  const ugCtx = document.getElementById('userGrowthChart')?.getContext('2d');
  if (ugCtx) {
    const growthData = <%= raw(@user_metrics[:registrations_by_day].to_json) %>;
    const labels = Object.keys(growthData).sort();
    new Chart(ugCtx, {
      type: 'bar',
      data: {
        labels: labels.map(d => d.slice(5)),
        datasets: [{
          label: 'New Users',
          data: labels.map(d => growthData[d]),
          backgroundColor: 'rgba(0,212,170,0.3)',
          borderColor: '#00D4AA',
          borderWidth: 1, borderRadius: 3, barThickness: 8
        }]
      },
      options: chartDefaults
    });
  }
});
</script>
