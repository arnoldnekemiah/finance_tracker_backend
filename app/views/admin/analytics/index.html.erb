<% content_for :page_title, "Analytics & Reports" %>
<% content_for :page_description, "Platform intelligence dashboard" %>

<div class="space-y-6">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <%= link_to admin_analytics_user_growth_path, class: "card p-5 animate-card hover:border-accent/30 group" do %>
      <div class="flex items-center gap-3 mb-2">
        <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center">
          <i data-lucide="users" class="w-5 h-5 text-accent"></i>
        </div>
        <h3 class="text-sm font-semibold text-fg-primary group-hover:text-accent transition-colors">User Growth</h3>
      </div>
      <p class="text-xs text-fg-muted">Registration trends, provider distribution, retention metrics</p>
    <% end %>

    <%= link_to admin_analytics_transaction_volume_path, class: "card p-5 animate-card hover:border-accent/30 group" do %>
      <div class="flex items-center gap-3 mb-2">
        <div class="w-10 h-10 rounded-lg bg-blue-500/10 flex items-center justify-center">
          <i data-lucide="trending-up" class="w-5 h-5 text-blue-400"></i>
        </div>
        <h3 class="text-sm font-semibold text-fg-primary group-hover:text-blue-400 transition-colors">Transaction Volume</h3>
      </div>
      <p class="text-xs text-fg-muted">Daily volume, income vs expenses, payment methods</p>
    <% end %>

    <%= link_to admin_analytics_financial_insights_path, class: "card p-5 animate-card hover:border-accent/30 group" do %>
      <div class="flex items-center gap-3 mb-2">
        <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center">
          <i data-lucide="bar-chart-3" class="w-5 h-5 text-purple-400"></i>
        </div>
        <h3 class="text-sm font-semibold text-fg-primary group-hover:text-purple-400 transition-colors">Financial Insights</h3>
      </div>
      <p class="text-xs text-fg-muted">Savings rate, category spending, account health</p>
    <% end %>

    <%= link_to admin_analytics_user_activity_path, class: "card p-5 animate-card hover:border-accent/30 group" do %>
      <div class="flex items-center gap-3 mb-2">
        <div class="w-10 h-10 rounded-lg bg-amber-500/10 flex items-center justify-center">
          <i data-lucide="activity" class="w-5 h-5 text-amber-400"></i>
        </div>
        <h3 class="text-sm font-semibold text-fg-primary group-hover:text-amber-400 transition-colors">User Activity</h3>
      </div>
      <p class="text-xs text-fg-muted">Engagement, top users, activity heatmap</p>
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <%= link_to admin_analytics_revenue_analytics_path, class: "card p-5 animate-card hover:border-accent/30 group" do %>
      <div class="flex items-center gap-3 mb-2">
        <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center">
          <i data-lucide="wallet" class="w-5 h-5 text-emerald-400"></i>
        </div>
        <h3 class="text-sm font-semibold text-fg-primary group-hover:text-emerald-400 transition-colors">Revenue Analytics</h3>
      </div>
      <p class="text-xs text-fg-muted">Platform AUM, user segmentation, lifetime value</p>
    <% end %>

    <%= link_to admin_analytics_export_data_path(data_type: 'users'), class: "card p-5 animate-card hover:border-accent/30 group" do %>
      <div class="flex items-center gap-3 mb-2">
        <div class="w-10 h-10 rounded-lg bg-red-500/10 flex items-center justify-center">
          <i data-lucide="download" class="w-5 h-5 text-red-400"></i>
        </div>
        <h3 class="text-sm font-semibold text-fg-primary group-hover:text-red-400 transition-colors">Export Data</h3>
      </div>
      <p class="text-xs text-fg-muted">Download users, transactions, debts, saving goals as CSV</p>
    <% end %>
  </div>
</div>
