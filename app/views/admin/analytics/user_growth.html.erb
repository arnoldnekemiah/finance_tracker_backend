<% content_for :page_title, "User Growth Analytics" %>
<% content_for :page_description, "Registration trends and user segmentation" %>

<div class="space-y-6">
  <!-- Date Range Filter -->
  <div class="card p-4 animate-card">
    <%= form_with url: admin_analytics_user_growth_path, method: :get, local: true, class: "flex flex-wrap items-end gap-3" do |f| %>
      <div>
        <label class="block text-[10px] font-mono uppercase tracking-wider text-fg-muted mb-1">From</label>
        <%= f.date_field :start_date, value: @start_date&.to_date,
            class: "px-3 py-2 rounded-lg bg-surface-50 border border-surface-400 text-fg-secondary text-sm outline-none focus:border-accent" %>
      </div>
      <div>
        <label class="block text-[10px] font-mono uppercase tracking-wider text-fg-muted mb-1">To</label>
        <%= f.date_field :end_date, value: @end_date&.to_date,
            class: "px-3 py-2 rounded-lg bg-surface-50 border border-surface-400 text-fg-secondary text-sm outline-none focus:border-accent" %>
      </div>
      <%= f.submit "Apply", class: "px-5 py-2 rounded-lg bg-accent text-surface-50 text-sm font-semibold cursor-pointer hover:bg-accent-light transition-colors" %>
    <% end %>
  </div>

  <!-- KPI Cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase tracking-wider text-fg-muted">Total Users</span>
      <p class="text-xl font-bold text-fg-primary font-mono mt-1"><%= number_with_delimiter(@metrics[:total_users]) %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase tracking-wider text-fg-muted">Active</span>
      <p class="text-xl font-bold text-accent font-mono mt-1"><%= number_with_delimiter(@metrics[:active_users]) %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase tracking-wider text-fg-muted">New (Period)</span>
      <p class="text-xl font-bold text-blue-400 font-mono mt-1"><%= @metrics[:new_users_period] %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase tracking-wider text-fg-muted">Inactive</span>
      <p class="text-xl font-bold text-red-400 font-mono mt-1"><%= @metrics[:inactive_users] %></p>
    </div>
  </div>

  <!-- Charts -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-1">Daily Registrations</h3>
      <p class="text-xs text-fg-muted font-mono mb-4">New users per day</p>
      <canvas id="dailyRegChart" height="200"></canvas>
    </div>
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-1">Monthly Registrations</h3>
      <p class="text-xs text-fg-muted font-mono mb-4">12-month view</p>
      <canvas id="monthlyRegChart" height="200"></canvas>
    </div>
  </div>

  <!-- Provider & Retention -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-4">Auth Provider Distribution</h3>
      <div class="space-y-3">
        <% @metrics[:provider_distribution].each do |provider, count| %>
          <div class="flex items-center justify-between">
            <span class="text-xs text-fg-secondary"><%= (provider || 'email').capitalize %></span>
            <div class="flex items-center gap-2">
              <div class="w-32 h-2 bg-surface-300 rounded-full overflow-hidden">
                <% pct = @metrics[:total_users] > 0 ? (count.to_f / @metrics[:total_users] * 100) : 0 %>
                <div class="h-full bg-accent rounded-full" style="width: <%= pct %>%"></div>
              </div>
              <span class="text-xs font-mono text-fg-primary"><%= count %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-4">Retention</h3>
      <div class="space-y-4">
        <div class="bg-surface-50 rounded-lg p-3 border border-surface-300">
          <p class="text-xs text-fg-muted font-mono">Active Last 7 Days</p>
          <p class="text-lg font-bold text-accent font-mono"><%= @metrics[:retention][:users_active_last_7d] %></p>
        </div>
        <div class="bg-surface-50 rounded-lg p-3 border border-surface-300">
          <p class="text-xs text-fg-muted font-mono">Active Last 30 Days</p>
          <p class="text-lg font-bold text-blue-400 font-mono"><%= @metrics[:retention][:users_active_last_30d] %></p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const chartOpts = {
    responsive: true, plugins: { legend: { display: false } },
    scales: {
      x: { grid: { color: '#21262D' }, ticks: { color: '#484F58', font: { family: 'IBM Plex Mono', size: 10 } } },
      y: { grid: { color: '#21262D' }, ticks: { color: '#484F58', font: { family: 'IBM Plex Mono', size: 10 } }, beginAtZero: true }
    }
  };
  const dailyData = <%= raw @metrics[:registrations_by_day].to_json %>;
  const dailyLabels = Object.keys(dailyData).sort();
  new Chart(document.getElementById('dailyRegChart'), {
    type: 'bar', data: {
      labels: dailyLabels.map(d => d.slice(5)),
      datasets: [{ data: dailyLabels.map(d => dailyData[d]), backgroundColor: 'rgba(0,212,170,0.3)', borderColor: '#00D4AA', borderWidth: 1, borderRadius: 3, barThickness: 8 }]
    }, options: chartOpts
  });
  const monthlyData = <%= raw @metrics[:registrations_by_month].to_json %>;
  const monthlyLabels = Object.keys(monthlyData).sort();
  new Chart(document.getElementById('monthlyRegChart'), {
    type: 'line', data: {
      labels: monthlyLabels,
      datasets: [{ data: monthlyLabels.map(m => monthlyData[m]), borderColor: '#00D4AA', backgroundColor: 'rgba(0,212,170,0.08)', tension: 0.4, fill: true, borderWidth: 2, pointRadius: 3, pointBackgroundColor: '#00D4AA' }]
    }, options: chartOpts
  });
});
</script>
