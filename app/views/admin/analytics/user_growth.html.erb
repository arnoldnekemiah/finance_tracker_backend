<div class="p-6">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">User Growth Analytics</h1>
    <p class="text-gray-600">Track user registration trends and growth patterns</p>
  </div>

  <!-- Date Range Filter -->
  <div class="bg-white rounded-lg shadow mb-6 p-6">
    <%= form_with url: admin_analytics_user_growth_path, method: :get, local: true, class: "flex items-end space-x-4" do |form| %>
      <div>
        <%= form.label :start_date, "Start Date", class: "block text-sm font-medium text-gray-700" %>
        <%= form.date_field :start_date, value: @start_date&.strftime('%Y-%m-%d'), class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
      </div>
      <div>
        <%= form.label :end_date, "End Date", class: "block text-sm font-medium text-gray-700" %>
        <%= form.date_field :end_date, value: @end_date&.strftime('%Y-%m-%d'), class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
      </div>
      <div>
        <%= form.submit "Update", class: "gold-bg text-black px-4 py-2 rounded-md font-medium hover:opacity-90" %>
      </div>
    <% end %>
  </div>

  <!-- Metrics Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="admin-card bg-white p-6 rounded-lg shadow">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-blue-100 text-blue-600">
          <i class="fas fa-users"></i>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-600">Total Users</p>
          <p class="text-2xl font-semibold text-gray-900"><%= @metrics[:total_users] %></p>
        </div>
      </div>
    </div>

    <div class="admin-card bg-white p-6 rounded-lg shadow">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-green-100 text-green-600">
          <i class="fas fa-user-plus"></i>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-600">New Users (Period)</p>
          <p class="text-2xl font-semibold text-gray-900"><%= @metrics[:new_users_period] %></p>
        </div>
      </div>
    </div>

    <div class="admin-card bg-white p-6 rounded-lg shadow">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-purple-100 text-purple-600">
          <i class="fas fa-chart-line"></i>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-600">Active Users (Period)</p>
          <p class="text-2xl font-semibold text-gray-900"><%= @metrics[:active_users_period] %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Growth Chart -->
  <div class="bg-white rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">User Registration Trend</h3>
    </div>
    <div class="p-6">
      <canvas id="userGrowthChart" width="400" height="200"></canvas>
    </div>
  </div>

  <!-- Back to Analytics -->
  <div class="mt-8">
    <%= link_to admin_analytics_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" do %>
      <i class="fas fa-arrow-left mr-2"></i>
      Back to Analytics Overview
    <% end %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // User Growth Chart
  const ctx = document.getElementById('userGrowthChart').getContext('2d');
  new Chart(ctx, {
    type: 'line',
    data: {
      labels: <%= raw @metrics[:registrations_by_day].keys.to_json %>,
      datasets: [{
        label: 'New Users',
        data: <%= raw @metrics[:registrations_by_day].values.to_json %>,
        borderColor: 'rgb(59, 130, 246)',
        backgroundColor: 'rgba(59, 130, 246, 0.1)',
        tension: 0.4
      }]
    },
    options: {
      responsive: true,
      plugins: {
        title: {
          display: true,
          text: 'Daily User Registrations'
        }
      },
      scales: {
        y: {
          beginAtZero: true
        }
      }
    }
  });
</script>

<style>
  .gold-bg {
    background: linear-gradient(45deg, #FFD700, #FFA500);
  }
</style>
