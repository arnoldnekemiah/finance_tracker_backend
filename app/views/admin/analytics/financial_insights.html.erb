<% content_for :page_title, "Financial Insights" %>
<% content_for :page_description, "Platform-wide financial health" %>

<div class="space-y-6">
  <div class="card p-4 animate-card">
    <%= form_with url: admin_analytics_financial_insights_path, method: :get, local: true, class: "flex flex-wrap items-end gap-3" do |f| %>
      <div>
        <label class="block text-[10px] font-mono uppercase tracking-wider text-fg-muted mb-1">From</label>
        <%= f.date_field :start_date, value: @start_date&.to_date, class: "px-3 py-2 rounded-lg bg-surface-50 border border-surface-400 text-fg-secondary text-sm outline-none focus:border-accent" %>
      </div>
      <div>
        <label class="block text-[10px] font-mono uppercase tracking-wider text-fg-muted mb-1">To</label>
        <%= f.date_field :end_date, value: @end_date&.to_date, class: "px-3 py-2 rounded-lg bg-surface-50 border border-surface-400 text-fg-secondary text-sm outline-none focus:border-accent" %>
      </div>
      <%= f.submit "Apply", class: "px-5 py-2 rounded-lg bg-accent text-surface-50 text-sm font-semibold cursor-pointer hover:bg-accent-light transition-colors" %>
    <% end %>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase text-fg-muted">Total Income</span>
      <p class="text-xl font-bold text-accent font-mono mt-1">$<%= number_with_delimiter(@insights[:total_income]) %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase text-fg-muted">Total Expenses</span>
      <p class="text-xl font-bold text-red-400 font-mono mt-1">$<%= number_with_delimiter(@insights[:total_expenses]) %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase text-fg-muted">Net Savings</span>
      <p class="text-xl font-bold font-mono mt-1 <%= @insights[:net_savings] >= 0 ? 'text-accent' : 'text-red-400' %>">$<%= number_with_delimiter(@insights[:net_savings]) %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase text-fg-muted">Savings Rate</span>
      <p class="text-xl font-bold text-blue-400 font-mono mt-1"><%= @insights[:savings_rate] %>%</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-4">Top Expense Categories</h3>
      <div class="space-y-3">
        <% @insights[:top_expense_categories].each do |cat| %>
          <div class="flex items-center justify-between">
            <span class="text-xs text-fg-secondary"><%= cat[:category] %></span>
            <span class="text-xs font-mono text-fg-primary">$<%= number_with_delimiter(cat[:amount]) %></span>
          </div>
        <% end %>
      </div>
    </div>
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-4">Top Income Categories</h3>
      <div class="space-y-3">
        <% @insights[:top_income_categories].each do |cat| %>
          <div class="flex items-center justify-between">
            <span class="text-xs text-fg-secondary"><%= cat[:category] %></span>
            <span class="text-xs font-mono text-accent">$<%= number_with_delimiter(cat[:amount]) %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-3">Account Health</h3>
      <div class="space-y-2">
        <div class="flex justify-between"><span class="text-xs text-fg-muted">Total Balance</span><span class="text-xs font-mono text-fg-primary">$<%= number_with_delimiter(@insights[:total_account_balance]) %></span></div>
        <div class="flex justify-between"><span class="text-xs text-fg-muted">Asset Accounts</span><span class="text-xs font-mono text-accent">$<%= number_with_delimiter(@insights[:asset_account_balance]) %></span></div>
        <div class="flex justify-between"><span class="text-xs text-fg-muted">Debt Accounts</span><span class="text-xs font-mono text-red-400">$<%= number_with_delimiter(@insights[:debt_account_balance]) %></span></div>
      </div>
    </div>
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-3">Debt Summary</h3>
      <div class="space-y-2">
        <div class="flex justify-between"><span class="text-xs text-fg-muted">Outstanding</span><span class="text-xs font-mono text-amber-400">$<%= number_with_delimiter(@insights[:total_outstanding_debt]) %></span></div>
        <div class="flex justify-between"><span class="text-xs text-fg-muted">Overdue</span><span class="text-xs font-mono text-red-400">$<%= number_with_delimiter(@insights[:overdue_debt]) %></span></div>
      </div>
    </div>
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-3">Savings Goals</h3>
      <div class="space-y-2">
        <div class="flex justify-between"><span class="text-xs text-fg-muted">Target</span><span class="text-xs font-mono text-fg-primary">$<%= number_with_delimiter(@insights[:total_saving_goal_progress][:target]) %></span></div>
        <div class="flex justify-between"><span class="text-xs text-fg-muted">Saved</span><span class="text-xs font-mono text-accent">$<%= number_with_delimiter(@insights[:total_saving_goal_progress][:saved]) %></span></div>
        <% goal_pct = @insights[:total_saving_goal_progress][:target].to_f > 0 ? ((@insights[:total_saving_goal_progress][:saved].to_f / @insights[:total_saving_goal_progress][:target].to_f) * 100).round(1) : 0 %>
        <div class="mt-2 h-2 bg-surface-300 rounded-full overflow-hidden">
          <div class="h-full bg-accent rounded-full" style="width: <%= [goal_pct, 100].min %>%"></div>
        </div>
        <p class="text-[10px] font-mono text-fg-muted text-center"><%= goal_pct %>% progress</p>
      </div>
    </div>
  </div>
</div>
