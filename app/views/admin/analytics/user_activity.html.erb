<div class="p-6">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">User Activity Analytics</h1>
    <p class="text-gray-600">Detailed analysis of user engagement and activity patterns</p>
  </div>

  <!-- Activity Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <% @activities.each do |event_type, count| %>
      <div class="admin-card bg-white p-6 rounded-lg shadow">
        <div class="flex items-center">
          <div class="p-3 rounded-full bg-blue-100 text-blue-600">
            <i class="fas fa-<%= event_type == 'admin_login' ? 'crown' : 'chart-line' %>"></i>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-600"><%= event_type.humanize %></p>
            <p class="text-2xl font-semibold text-gray-900"><%= count %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Top Active Users -->
  <div class="bg-white rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Top Active Users</h3>
    </div>
    <div class="p-6">
      <div class="space-y-4">
        <% @top_active_users.each do |user_data| %>
          <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
            <div class="flex items-center">
              <div class="w-10 h-10 bg-gold-bg rounded-full flex items-center justify-center text-white font-semibold">
                <%= user_data[:user][:name]&.first || 'U' %>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-gray-900"><%= user_data[:user][:name] %></p>
                <p class="text-sm text-gray-500"><%= user_data[:user][:email] %></p>
              </div>
            </div>
            <div class="text-right">
              <p class="text-sm font-medium text-gray-900"><%= user_data[:activity_count] %> activities</p>
              <p class="text-sm text-gray-500">Last 30 days</p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Recent Activities -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Recent Activities</h3>
    </div>
    <div class="p-6">
      <div class="space-y-3">
        <% @recent_activities.each do |activity| %>
          <div class="flex items-center justify-between py-3 border-b border-gray-100 last:border-b-0">
            <div class="flex items-center">
              <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                <i class="fas fa-<%= activity[:event_type] == 'admin_login' ? 'crown' : 'user' %> text-blue-600 text-xs"></i>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-gray-900">
                  <%= activity[:user][:name] %> - <%= activity[:event_type].humanize %>
                </p>
                <p class="text-sm text-gray-500"><%= activity[:user][:email] %></p>
              </div>
            </div>
            <div class="text-right">
              <p class="text-sm text-gray-500"><%= time_ago_in_words(activity[:created_at]) %> ago</p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Back to Analytics -->
  <div class="mt-8">
    <%= link_to admin_analytics_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" do %>
      <i class="fas fa-arrow-left mr-2"></i>
      Back to Analytics Overview
    <% end %>
  </div>
</div>

<style>
  .gold-bg {
    background: linear-gradient(45deg, #FFD700, #FFA500);
  }
</style>
