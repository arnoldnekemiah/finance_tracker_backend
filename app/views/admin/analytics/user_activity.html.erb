<% content_for :page_title, "User Activity" %>
<% content_for :page_description, "Engagement and activity metrics" %>

<div class="space-y-6">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase text-fg-muted">With Transactions</span>
      <p class="text-xl font-bold text-accent font-mono mt-1"><%= @engagement_metrics[:users_with_transactions] %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase text-fg-muted">No Transactions</span>
      <p class="text-xl font-bold text-red-400 font-mono mt-1"><%= @engagement_metrics[:users_without_transactions] %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase text-fg-muted">Avg Txns/User</span>
      <p class="text-xl font-bold text-blue-400 font-mono mt-1"><%= @engagement_metrics[:avg_transactions_per_user] %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase text-fg-muted">Monthly Avg</span>
      <p class="text-xl font-bold text-purple-400 font-mono mt-1"><%= @engagement_metrics[:avg_monthly_transactions] %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-4">Top Active Users</h3>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="text-left text-[11px] font-mono uppercase tracking-wider text-fg-muted border-b border-surface-300">
              <th class="pb-2 pr-4">#</th>
              <th class="pb-2 pr-4">User</th>
              <th class="pb-2 pr-4">Txns</th>
              <th class="pb-2">Volume</th>
            </tr>
          </thead>
          <tbody>
            <% @top_active_users.each_with_index do |entry, idx| %>
              <tr class="table-row border-b border-surface-300/50">
                <td class="py-2 pr-4 text-xs text-fg-muted font-mono"><%= idx + 1 %></td>
                <td class="py-2 pr-4">
                  <p class="text-sm text-fg-primary"><%= entry[:user][:name] %></p>
                  <p class="text-[10px] text-fg-muted font-mono"><%= entry[:user][:email] %></p>
                </td>
                <td class="py-2 pr-4 text-xs text-fg-primary font-mono"><%= entry[:transaction_count] %></td>
                <td class="py-2 text-xs text-accent font-mono">$<%= number_with_delimiter(entry[:total_volume]) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-4">Recent Activity Feed</h3>
      <div class="space-y-3 max-h-[400px] overflow-y-auto">
        <% @recent_activities.each do |activity| %>
          <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-surface-200/50">
            <div class="w-7 h-7 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
              <span class="text-[9px] font-bold text-accent"><%= activity[:user][:name]&.first %></span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs text-fg-primary truncate"><%= activity[:user][:name] %></p>
              <p class="text-[10px] text-fg-muted font-mono"><%= activity[:event_type] %> · $<%= activity[:amount] %></p>
            </div>
            <span class="text-[10px] text-fg-muted font-mono flex-shrink-0"><%= time_ago_in_words(activity[:created_at]) %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
