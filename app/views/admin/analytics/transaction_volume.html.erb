<% content_for :page_title, "Transaction Volume" %>
<% content_for :page_description, "Volume analysis and payment breakdown" %>

<div class="space-y-6">
  <div class="card p-4 animate-card">
    <%= form_with url: admin_analytics_transaction_volume_path, method: :get, local: true, class: "flex flex-wrap items-end gap-3" do |f| %>
      <div>
        <label class="block text-[10px] font-mono uppercase tracking-wider text-fg-muted mb-1">From</label>
        <%= f.date_field :start_date, value: @start_date&.to_date, class: "px-3 py-2 rounded-lg bg-surface-50 border border-surface-400 text-fg-secondary text-sm outline-none focus:border-accent" %>
      </div>
      <div>
        <label class="block text-[10px] font-mono uppercase tracking-wider text-fg-muted mb-1">To</label>
        <%= f.date_field :end_date, value: @end_date&.to_date, class: "px-3 py-2 rounded-lg bg-surface-50 border border-surface-400 text-fg-secondary text-sm outline-none focus:border-accent" %>
      </div>
      <%= f.submit "Apply", class: "px-5 py-2 rounded-lg bg-accent text-surface-50 text-sm font-semibold cursor-pointer hover:bg-accent-light transition-colors" %>
    <% end %>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase tracking-wider text-fg-muted">Total</span>
      <p class="text-xl font-bold text-fg-primary font-mono mt-1"><%= number_with_delimiter(@metrics[:total_transactions]) %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase tracking-wider text-fg-muted">Income Volume</span>
      <p class="text-xl font-bold text-accent font-mono mt-1">$<%= number_with_delimiter(@metrics[:total_income_volume]) %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase tracking-wider text-fg-muted">Expense Volume</span>
      <p class="text-xl font-bold text-red-400 font-mono mt-1">$<%= number_with_delimiter(@metrics[:total_expense_volume]) %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase tracking-wider text-fg-muted">Avg Amount</span>
      <p class="text-xl font-bold text-blue-400 font-mono mt-1">$<%= @metrics[:avg_transaction_amount] %></p>
    </div>
  </div>

  <div class="card p-5 animate-card">
    <h3 class="text-sm font-semibold text-fg-primary mb-1">Income vs Expenses</h3>
    <p class="text-xs text-fg-muted font-mono mb-4">Daily volume comparison</p>
    <canvas id="volumeChart" height="250"></canvas>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const income = <%= raw @metrics[:income_by_day].to_json %>;
  const expenses = <%= raw @metrics[:expenses_by_day].to_json %>;
  const dates = [...new Set([...Object.keys(income), ...Object.keys(expenses)])].sort();
  new Chart(document.getElementById('volumeChart'), {
    type: 'line', data: {
      labels: dates.map(d => d.slice(5)),
      datasets: [
        { label: 'Income', data: dates.map(d => income[d] || 0), borderColor: '#00D4AA', backgroundColor: 'rgba(0,212,170,0.08)', tension: 0.4, fill: true, borderWidth: 2, pointRadius: 0 },
        { label: 'Expenses', data: dates.map(d => expenses[d] || 0), borderColor: '#F85149', backgroundColor: 'rgba(248,81,73,0.05)', tension: 0.4, fill: true, borderWidth: 2, pointRadius: 0 }
      ]
    },
    options: {
      responsive: true, plugins: { legend: { labels: { color: '#8B949E', font: { family: 'IBM Plex Mono', size: 11 } } } },
      scales: {
        x: { grid: { color: '#21262D' }, ticks: { color: '#484F58', font: { family: 'IBM Plex Mono', size: 10 } } },
        y: { grid: { color: '#21262D' }, ticks: { color: '#484F58', font: { family: 'IBM Plex Mono', size: 10 } }, beginAtZero: true }
      }
    }
  });
});
</script>
