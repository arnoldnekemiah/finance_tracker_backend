<div class="p-6">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Revenue Analytics</h1>
    <p class="text-gray-600">Monitor revenue metrics and user lifetime value</p>
  </div>

  <!-- Revenue Metrics Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="admin-card bg-white p-6 rounded-lg shadow">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-blue-100 text-blue-600">
          <i class="fas fa-users"></i>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-600">Total Users</p>
          <p class="text-2xl font-semibold text-gray-900"><%= number_with_delimiter(@revenue_data[:total_users]) %></p>
        </div>
      </div>
    </div>

    <div class="admin-card bg-white p-6 rounded-lg shadow">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-yellow-100 text-yellow-600">
          <i class="fas fa-crown"></i>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-600">Premium Users</p>
          <p class="text-2xl font-semibold text-gray-900"><%= number_with_delimiter(@revenue_data[:premium_users]) %></p>
          <p class="text-xs text-gray-500">Feature not implemented</p>
        </div>
      </div>
    </div>

    <div class="admin-card bg-white p-6 rounded-lg shadow">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-green-100 text-green-600">
          <i class="fas fa-dollar-sign"></i>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-600">Monthly Recurring Revenue</p>
          <p class="text-2xl font-semibold text-gray-900">$<%= number_with_delimiter(@revenue_data[:monthly_recurring_revenue]) %></p>
          <p class="text-xs text-gray-500">Feature not implemented</p>
        </div>
      </div>
    </div>

    <div class="admin-card bg-white p-6 rounded-lg shadow">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-purple-100 text-purple-600">
          <i class="fas fa-chart-line"></i>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-600">User Lifetime Value</p>
          <p class="text-2xl font-semibold text-gray-900">$<%= number_with_delimiter(@revenue_data[:user_lifetime_value] || 0) %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Churn Rate Section -->
  <div class="bg-white rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">User Retention Metrics</h3>
    </div>
    <div class="p-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="text-center">
          <div class="text-3xl font-bold text-red-600 mb-2">
            <%= number_to_percentage(@revenue_data[:churn_rate] || 0, precision: 1) %>
          </div>
          <p class="text-gray-600">Churn Rate</p>
          <p class="text-sm text-gray-500 mt-1">Users who stopped using the app</p>
        </div>
        
        <div class="text-center">
          <div class="text-3xl font-bold text-green-600 mb-2">
            <%= number_to_percentage(100 - (@revenue_data[:churn_rate] || 0), precision: 1) %>
          </div>
          <p class="text-gray-600">Retention Rate</p>
          <p class="text-sm text-gray-500 mt-1">Users who continue using the app</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Revenue Opportunities -->
  <div class="bg-white rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Revenue Opportunities</h3>
    </div>
    <div class="p-6">
      <div class="space-y-4">
        <div class="flex items-start space-x-3">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
              <i class="fas fa-lightbulb text-blue-600 text-sm"></i>
            </div>
          </div>
          <div>
            <h4 class="text-sm font-medium text-gray-900">Premium Features</h4>
            <p class="text-sm text-gray-600">Implement premium subscription tiers with advanced analytics, unlimited budgets, and priority support.</p>
          </div>
        </div>
        
        <div class="flex items-start space-x-3">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
              <i class="fas fa-chart-bar text-green-600 text-sm"></i>
            </div>
          </div>
          <div>
            <h4 class="text-sm font-medium text-gray-900">Advanced Reporting</h4>
            <p class="text-sm text-gray-600">Offer detailed financial reports and insights as a paid add-on service.</p>
          </div>
        </div>
        
        <div class="flex items-start space-x-3">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center">
              <i class="fas fa-mobile-alt text-purple-600 text-sm"></i>
            </div>
          </div>
          <div>
            <h4 class="text-sm font-medium text-gray-900">Mobile App</h4>
            <p class="text-sm text-gray-600">Develop mobile applications with premium features and in-app purchases.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Back to Analytics -->
  <div class="mt-8">
    <%= link_to admin_analytics_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" do %>
      <i class="fas fa-arrow-left mr-2"></i>
      Back to Analytics Overview
    <% end %>
  </div>
</div>

<style>
  .gold-bg {
    background: linear-gradient(45deg, #FFD700, #FFA500);
  }
</style>
