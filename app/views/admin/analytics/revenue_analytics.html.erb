<% content_for :page_title, "Revenue Analytics" %>
<% content_for :page_description, "Platform value and user segmentation" %>

<div class="space-y-6">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase text-fg-muted">Platform AUM</span>
      <p class="text-xl font-bold text-accent font-mono mt-1">$<%= number_with_delimiter(@revenue_data[:platform_aum]) %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase text-fg-muted">Debt Tracked</span>
      <p class="text-xl font-bold text-amber-400 font-mono mt-1">$<%= number_with_delimiter(@revenue_data[:total_debt_tracked]) %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase text-fg-muted">Savings Tracked</span>
      <p class="text-xl font-bold text-blue-400 font-mono mt-1">$<%= number_with_delimiter(@revenue_data[:total_savings_tracked]) %></p>
    </div>
    <div class="card p-4 animate-card">
      <span class="text-[10px] font-mono uppercase text-fg-muted">Churn Rate</span>
      <p class="text-xl font-bold text-red-400 font-mono mt-1"><%= @revenue_data[:churn_rate] %>%</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-4">Monthly Transaction Volume</h3>
      <canvas id="monthlyVolumeChart" height="200"></canvas>
    </div>
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-4">User Segments</h3>
      <div class="space-y-4">
        <% segments = @revenue_data[:user_segments] %>
        <% total = segments.values.sum.to_f %>
        <% [
          ['High Activity (20+ txns)', segments[:high_activity], 'bg-accent', 'text-accent'],
          ['Medium (5-19 txns)', segments[:medium_activity], 'bg-blue-400', 'text-blue-400'],
          ['Low (1-4 txns)', segments[:low_activity], 'bg-amber-400', 'text-amber-400'],
          ['No Activity', segments[:no_activity], 'bg-red-400', 'text-red-400']
        ].each do |label, count, bar_color, text_color| %>
          <div>
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs text-fg-secondary"><%= label %></span>
              <span class="text-xs font-mono <%= text_color %>"><%= count %></span>
            </div>
            <div class="h-2 bg-surface-300 rounded-full overflow-hidden">
              <div class="h-full <%= bar_color %> rounded-full" style="width: <%= total > 0 ? (count / total * 100).round(1) : 0 %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="card p-5 animate-card">
      <h3 class="text-sm font-semibold text-fg-primary mb-3">Value Metrics</h3>
      <div class="space-y-3">
        <div class="flex justify-between"><span class="text-xs text-fg-muted">Avg Txn Volume/User</span><span class="text-xs font-mono text-fg-primary">$<%= number_with_delimiter(@revenue_data[:avg_user_transaction_volume]) %></span></div>
        <div class="flex justify-between"><span class="text-xs text-fg-muted">User Lifetime Value</span><span class="text-xs font-mono text-accent">$<%= number_with_delimiter(@revenue_data[:user_lifetime_value]) %></span></div>
        <div class="flex justify-between"><span class="text-xs text-fg-muted">Active Users</span><span class="text-xs font-mono text-fg-primary"><%= @revenue_data[:active_users] %></span></div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const monthlyData = <%= raw @revenue_data[:monthly_transaction_volume].to_json %>;
  new Chart(document.getElementById('monthlyVolumeChart'), {
    type: 'bar', data: {
      labels: monthlyData.map(m => m.month),
      datasets: [
        { label: 'Income', data: monthlyData.map(m => m.income), backgroundColor: 'rgba(0,212,170,0.4)', borderColor: '#00D4AA', borderWidth: 1, borderRadius: 3 },
        { label: 'Expenses', data: monthlyData.map(m => m.expenses), backgroundColor: 'rgba(248,81,73,0.3)', borderColor: '#F85149', borderWidth: 1, borderRadius: 3 }
      ]
    },
    options: {
      responsive: true, plugins: { legend: { labels: { color: '#8B949E', font: { family: 'IBM Plex Mono', size: 11 } } } },
      scales: {
        x: { grid: { color: '#21262D' }, ticks: { color: '#484F58', font: { family: 'IBM Plex Mono', size: 10 } } },
        y: { grid: { color: '#21262D' }, ticks: { color: '#484F58', font: { family: 'IBM Plex Mono', size: 10 } }, beginAtZero: true }
      }
    }
  });
});
</script>
