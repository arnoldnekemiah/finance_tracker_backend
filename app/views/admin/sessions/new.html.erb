<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — Accountanta</title>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

  <style>
    body { font-family: 'DM Sans', sans-serif; }
    .font-mono { font-family: 'IBM Plex Mono', monospace; }
    .login-bg {
      background: #0D1117;
      position: relative;
      overflow: hidden;
    }
    .login-bg::before {
      content: '';
      position: absolute;
      width: 600px; height: 600px;
      background: radial-gradient(circle, rgba(0,212,170,0.06) 0%, transparent 70%);
      top: -200px; right: -200px;
      border-radius: 50%;
    }
    .login-bg::after {
      content: '';
      position: absolute;
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(0,212,170,0.04) 0%, transparent 70%);
      bottom: -100px; left: -100px;
      border-radius: 50%;
    }
    .login-card {
      background: rgba(22, 27, 34, 0.9);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(48, 54, 61, 0.8);
    }
    .input-field {
      background: rgba(13, 17, 23, 0.8);
      border: 1px solid #30363D;
      transition: all 0.2s;
      color: #E6EDF3;
    }
    .input-field:focus {
      background: rgba(13, 17, 23, 1);
      border-color: #00D4AA;
      box-shadow: 0 0 0 3px rgba(0,212,170,0.15);
    }
    .input-field::placeholder { color: #484F58; }
    .btn-login {
      background: linear-gradient(135deg, #00D4AA, #00B894);
      transition: all 0.3s;
    }
    .btn-login:hover {
      background: linear-gradient(135deg, #00F5C8, #00D4AA);
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(0,212,170,0.25);
    }
    .divider { position: relative; }
    .divider::before, .divider::after {
      content: ''; position: absolute; top: 50%; width: 42%; height: 1px; background: #30363D;
    }
    .divider::before { left: 0; }
    .divider::after { right: 0; }
  </style>
</head>
<body class="login-bg min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-md relative z-10">
    <div class="login-card rounded-2xl p-8" id="login-card">
      <div class="text-center mb-8">
        <div class="mx-auto w-14 h-14 rounded-xl bg-gradient-to-br from-[#00D4AA] to-[#00B894] flex items-center justify-center mb-4 shadow-lg" style="box-shadow: 0 4px 20px rgba(0,212,170,0.3);">
          <i data-lucide="bar-chart-3" class="w-7 h-7 text-[#0D1117]"></i>
        </div>
        <h1 class="text-2xl font-bold text-white">Accountanta</h1>
        <p class="text-[#8B949E] text-xs mt-1 font-mono uppercase tracking-widest">Admin Console</p>
      </div>

      <%= form_with url: admin_login_path, method: :post, local: true, class: "space-y-5" do |form| %>
        <% if flash[:alert] %>
          <div class="p-3 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 text-sm flex items-center gap-2">
            <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
            <%= flash[:alert] %>
          </div>
        <% end %>
        <% if flash[:notice] %>
          <div class="p-3 rounded-lg bg-[#00D4AA]/10 border border-[#00D4AA]/20 text-[#00D4AA] text-sm flex items-center gap-2">
            <i data-lucide="check-circle-2" class="w-4 h-4 flex-shrink-0"></i>
            <%= flash[:notice] %>
          </div>
        <% end %>

        <div>
          <label class="block text-xs font-medium text-[#8B949E] mb-1.5 font-mono uppercase tracking-wider">Email</label>
          <%= form.email_field :email, required: true, autocomplete: "email",
              class: "input-field w-full px-4 py-3 rounded-lg text-sm outline-none",
              placeholder: "admin@accountanta.com" %>
        </div>

        <div>
          <label class="block text-xs font-medium text-[#8B949E] mb-1.5 font-mono uppercase tracking-wider">Password</label>
          <%= form.password_field :password, required: true, autocomplete: "current-password",
              class: "input-field w-full px-4 py-3 rounded-lg text-sm outline-none",
              placeholder: "Enter password" %>
        </div>

        <div class="flex items-center justify-between">
          <label class="flex items-center gap-2 cursor-pointer">
            <%= form.check_box :remember_me, class: "w-4 h-4 rounded bg-[#0D1117] border-[#30363D] text-[#00D4AA] focus:ring-[#00D4AA]/30" %>
            <span class="text-sm text-[#8B949E]">Remember me</span>
          </label>
          <%= link_to "Forgot password?", "#", class: "text-sm text-[#00D4AA] hover:text-[#00F5C8] transition-colors", id: "forgot-password-link" %>
        </div>

        <%= form.submit "Sign In", class: "btn-login w-full py-3 rounded-lg text-sm font-semibold text-[#0D1117] cursor-pointer" %>
      <% end %>

      <!-- Forgot Password Form (hidden by default) -->
      <div id="forgot-password-form" class="hidden mt-6 pt-6 border-t border-[#21262D]">
        <%= form_with url: admin_send_reset_otp_path, method: :post, local: true, class: "space-y-4" do |form| %>
          <p class="text-sm text-[#8B949E]">Enter your admin email to receive a password reset code.</p>
          <div>
            <%= form.email_field :email, required: true,
                class: "input-field w-full px-4 py-3 rounded-lg text-sm outline-none",
                placeholder: "admin@accountanta.com" %>
          </div>
          <%= form.submit "Send Reset Code", class: "btn-login w-full py-2.5 rounded-lg text-sm font-semibold text-[#0D1117] cursor-pointer" %>
          <button type="button" id="back-to-login" class="w-full py-2 text-sm text-[#8B949E] hover:text-[#00D4AA] transition-colors">
            Back to login
          </button>
        <% end %>
      </div>
    </div>

    <p class="text-center text-[#484F58] text-xs mt-6 font-mono">
      &copy; <%= Date.current.year %> Accountanta &middot; Financial Control Center
    </p>
  </div>

  <script>lucide.createIcons();</script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const card = document.getElementById('login-card');
      card.style.opacity = '0';
      card.style.transform = 'translateY(16px)';
      requestAnimationFrame(() => {
        card.style.transition = 'all 0.5s cubic-bezier(0.16,1,0.3,1)';
        card.style.opacity = '1';
        card.style.transform = 'translateY(0)';
      });

      const forgotLink = document.getElementById('forgot-password-link');
      const forgotForm = document.getElementById('forgot-password-form');
      const backBtn = document.getElementById('back-to-login');
      if (forgotLink && forgotForm) {
        forgotLink.addEventListener('click', (e) => {
          e.preventDefault();
          forgotForm.classList.toggle('hidden');
        });
        backBtn.addEventListener('click', () => {
          forgotForm.classList.add('hidden');
        });
      }
    });
  </script>
</body>
</html>
