# ─────────────────────────────────────────────────────────────
# Accountanta API — Production Environment Variables
# Copy to .env on the Droplet and fill in every value.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Rails ───────────────────────────────────────────────────
RAILS_ENV=production
RAILS_MASTER_KEY=                        # content of config/master.key
RAILS_LOG_LEVEL=info
RAILS_SERVE_STATIC_FILES=true
# Set to "true" ONLY when running behind HTTPS (Nginx with SSL / domain + Let's Encrypt).
# Leave blank/false for raw IP HTTP deployments — otherwise admin sessions will break.
SESSION_SECURE_COOKIE=false
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2
PORT=3000
APP_HOST=<your-droplet-ip>               # raw Droplet IP, e.g. 167.99.12.34 — or api.yourdomain.com if you have a domain

# ── Database (Neon Serverless PostgreSQL) ────────────────────
# Get this from your Neon dashboard → Project → Connection Details
# Select "Rails" or copy the connection string directly
DATABASE_URL=postgresql://USER:PASS@ep-xxxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── JWT / Auth ───────────────────────────────────────────────
JWT_SECRET_KEY=                          # run: openssl rand -hex 64

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Gmail SMTP) ───────────────────────────────────────
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=                      # Google App Password (not your account password)

# ── DigitalOcean Spaces (optional — for file uploads) ────────
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=accountanta-assets

# ── App URL (used in mailer links) ───────────────────────────
FRONTEND_URL=https://yourdomain.com
