# ─────────────────────────────────────────────────────────────
# Accountanta API — Production Environment Variables
# Copy to .env on the Droplet and fill in every value.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Rails ───────────────────────────────────────────────────
RAILS_ENV=production
RAILS_MASTER_KEY=                        # content of config/master.key
RAILS_LOG_LEVEL=info
RAILS_SERVE_STATIC_FILES=true
# Set to "true" in production for `https://admin.ikondesoft.com`.
# Only switch this to false if you intentionally serve production over plain HTTP.
SESSION_SECURE_COOKIE=true
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2
PORT=3000
ADMIN_APP_HOST=admin.ikondesoft.com
API_APP_HOST=accountanta.ikondesoft.com
APP_PROTOCOL=https

# ── Database (Neon Serverless PostgreSQL) ────────────────────
# Get this from your Neon dashboard → Project → Connection Details
# Select "Rails" or copy the connection string directly
DATABASE_URL=postgresql://USER:PASS@ep-xxxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── JWT / Auth ───────────────────────────────────────────────
JWT_SECRET_KEY=                          # run: openssl rand -hex 64

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Mailtrap SMTP) ─────────────────────────────────
# Sign up at https://mailtrap.io → Email Sending → SMTP Settings
# Free tier: 1,000 emails/month
MAILTRAP_USERNAME=Ikonde                       # from Mailtrap SMTP credentials
MAILTRAP_PASSWORD=Tca4bjs3@1998                    # from Mailtrap SMTP credentials
MAILER_FROM=noreply@ikondesoft.com       # displayed as the sender address

# ── DigitalOcean Spaces (optional — for file uploads) ────────
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=accountanta-assets

# ── App URLs ──────────────────────────────────────────────────
FRONTEND_URL=https://admin.ikondesoft.com
